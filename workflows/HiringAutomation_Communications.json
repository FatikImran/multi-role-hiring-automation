    {
      "parameters": {
        "fromEmail": "noreply@example.com",
        "toEmail": "={{$json.email}}",
        "subject": "Update on your application - {{$json.name}}",
        "html": "=<p>Dear {{$json.name}},</p><p>Thank you for taking the time to apply for the {{$json.role}} role at Trilles AI.</p><p>After reviewing your application, we will not be moving forward at this stage. This decision was based on the current needs of the role and the fit of the submitted materials.</p><p>We appreciate your interest and encourage you to apply again for future opportunities.</p><p>Kind regards,<br>Trilles AI Hiring Team</p>"
      },
      "id": "11",
